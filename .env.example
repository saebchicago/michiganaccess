# Copy to .env.local and fill in values. Never commit .env.local.
# See scripts/check-secrets.mjs for CI guards.

# --- Supabase (client-safe; VITE_ prefix is intentional) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PROJECT_ID=your-project-ref
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
# Optional alias used by some components:
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key

# --- Mistral AI (SERVER-SIDE ONLY - no VITE_ prefix) ---
# Netlify: Site settings > Environment variables
# Local Netlify dev: set here; never import from client code
MISTRAL_API_KEY=your-mistral-api-key

# --- Optional server-side data keys (Netlify / Supabase secrets) ---
# CENSUS_API_KEY=
# AIRNOW_API_KEY=
# EIA_API_KEY=
# SAM_API_KEY=
# MICHIGAN_OPEN_DATA_TOKEN=
# SUPABASE_SERVICE_ROLE_KEY=  # scripts/ingest only - never in frontend