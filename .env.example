# ============================================================
# Michigan Access - Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git
# ============================================================

# --- Supabase (frontend, safe to expose) ---
VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- Mistral AI ---
# SERVER-SIDE ONLY (Netlify env var) - used in netlify/functions/chat-mistral.js
# Set this in Netlify Dashboard > Site Settings > Environment Variables
# Do NOT prefix with VITE_ - must NOT be exposed to browser
MISTRAL_API_KEY=your-mistral-api-key

# Optional: override Netlify functions base URL for local dev
# (leave blank in production - defaults to /.netlify/functions)
VITE_NETLIFY_FUNCTIONS_URL=

# --- Michigan Open Data (Socrata) ---
# Free token from https://data.michigan.gov/profile/app_tokens
# Increases rate limits from ~1000 to 100,000 requests/day
# SERVER-SIDE ONLY - set in Netlify Dashboard, do NOT prefix with VITE_
MICHIGAN_OPEN_DATA_TOKEN=your-socrata-app-token

# --- Optional: additional data source keys ---
# Add here as you wire in more sources
# EGLE ArcGIS - public, no key needed
# CDC PLACES API - public, no key needed
# HRSA Data Warehouse - public, no key needed
# County Health Rankings - public, no key needed
